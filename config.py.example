# Scentified Marketing Suite — Environment Variable Reference
# Copy this file to config.py and fill in your values, or set these env vars.

# ── WooCommerce REST API ──────────────────────────────────────────
# Found in: WooCommerce → Settings → Advanced → REST API
STORE_URL = "https://scentifiedperfume.com"
WOO_CONSUMER_KEY = "ck_your_consumer_key_here"
WOO_CONSUMER_SECRET = "cs_your_consumer_secret_here"

# ── Google PageSpeed Insights ──────────────────────────────────────
# Get a key at: https://developers.google.com/speed/docs/insights
PAGESPEED_API_KEY = "AIzaSy_your_pagespeed_key_here"

# ── Internal (do not change) ──────────────────────────────────────
# These are derived/configured automatically:
monthly_visitors = 500
avg_order_value_ngn = 220000
usd_to_ngn = 1600
output_dir = "./audit_reports"
history_file = "./audit_reports/score_history.json"
